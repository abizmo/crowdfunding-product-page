---
import { Button } from './ui/button'
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle
} from './ui/card'

interface Props {
  reward: string
  value: number
  description: string
  stock: number
}

const { reward, value, description, stock } = Astro.props
---

<Card className={`${!stock && 'opacity-55'}`}>
  <CardHeader
    className='space-y-2 md:flex-row md:justify-between md:items-center'
  >
    <CardTitle className='text-sm font-bold md:text-lg'>{reward}</CardTitle>
    <p class='text-primary text-sm'>Pledge ${value} or more</p>
  </CardHeader>
  <CardContent className='mb-6'>
    <CardDescription className='leading-relaxed'>{description}</CardDescription>
  </CardContent>
  <CardFooter
    className='flex-col md:flex-row md:justify-between items-start md:items-center gap-y-6'
  >
    <p class='text-3xl font-bold text-foreground flex gap-2 items-center'>
      {stock}<span class='text-sm font-normal text-card-foreground'>left</span>
    </p>
    <Button disabled={!stock}
      >{stock === 0 ? 'Out of stock' : 'Select Reward'}</Button
    >
  </CardFooter>
</Card>
