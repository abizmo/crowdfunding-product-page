---
interface Props {
  large?: boolean;
  primary?: boolean;
  disabled?: boolean;
}
const { large = false, primary = false, disabled = false } = Astro.props;
---

<button class:list={['btn', { large, primary, disabled }]} disabled={disabled}>
  <slot />
</button>

<style>
  .btn {
    border: 0;
    font-weight: 500;
    padding: 0em 2em;
    border-radius: 50em;
    color: hsl(var(--white));
    height: 3.5rem;
  }

  .primary {
    background-color: hsl(var(--accent));
  }

  .primary:hover,
  .primary:focus {
    background-color: hsl(var(--accent-dark));
  }

  .large {
    width: 100%;
    max-width: 13.75rem;
  }

  .disabled {
    background-color: hsl(var(--dark-gray));
  }
</style>
