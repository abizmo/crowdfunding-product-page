---

---

<header class='primary-header'>
  <div class='container header-container'>
    <div class='nav-wrapper'>
      <a href='/' class='logo'>
        <img src='/images/logo.svg' alt='crowdfund' />
      </a>
      <button
        class='nav-toggle'
        aria-controls='primary-navigation'
        aria-expanded='false'
      >
        <img
          src='/images/icon-hamburger.svg'
          alt=''
          class='menu'
          aria-hidden='true'
        />
        <img
          src='/images/icon-close-menu.svg'
          alt=''
          class='close'
          aria-hidden='true'
        />
        <span class='sr-only'>menu</span>
      </button>
      <nav class='nav' id='primary-navigation'>
        <ul class='nav__list'>
          <li class='nav__item'>
            <a href='#' class='nav__link'>About</a>
          </li>
          <li class='nav__item'>
            <a href='#' class='nav__link'>Discover</a>
          </li>
          <li class='nav__item'>
            <a href='#' class='nav__link'>Get Started</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('.primary-header');
  const nav = document.querySelector('.nav');
  const navToggle = document.querySelector('.nav-toggle');

  navToggle?.addEventListener('click', () => {
    nav?.hasAttribute('data-visible')
      ? navToggle.setAttribute('aria-expanded', 'false')
      : navToggle.setAttribute('aria-expanded', 'true');
    nav?.toggleAttribute('data-visible');
    header?.toggleAttribute('data-overlay');
  });
</script>

<style>
  .header-container {
    --max-width: 70rem;
  }

  .primary-header {
    padding-block: 2em;
  }

  .nav-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav {
    display: none;

    position: fixed;
    inset: 5em var(--container-padding) auto;
    background-color: hsl(var(--white));
    border-radius: 1em;
    overflow: hidden;
    max-width: 25em;
    margin-inline: auto;
  }

  .primary-header[data-overlay]::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: linear-gradient(
      hsla(var(--black), 0.4),
      hsla(var(--black), 0)
    );
  }

  .primary-header * {
    z-index: 2;
  }

  .close {
    display: none;
  }

  .nav[data-visible] {
    display: block;
  }

  .nav-toggle {
    border: 0;
    background-color: transparent;
  }

  .nav-toggle[aria-expanded='true'] .close {
    display: inline;
  }

  .nav-toggle[aria-expanded='true'] .menu {
    display: none;
  }

  .nav__item + .nav__item {
    border-top: 1px solid hsla(var(--dark-gray), 0.2);
  }

  .nav__link {
    display: block;
    padding: 1.5em;
    color: hsl(var(--black));
    font-weight: 500;
    text-decoration: none;
    transition: all 300ms ease;
  }

  .nav__link:hover,
  .nav__link:focus {
    background-color: hsl(var(--accent));
    color: hsl(var(--white));
    outline: none;
  }
</style>
