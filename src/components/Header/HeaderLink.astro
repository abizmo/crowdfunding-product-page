---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<li class='nav__item'>
  <a href='#' class='nav__link'>
    <slot />
  </a>
</li>

<style>
  .nav__link {
    font-weight: 500;
    text-decoration: none;
    transition: all 300ms ease;
    outline: none;
    font-size: var(--fs-600);
  }

  @media (max-width: 999.999px) {
    .nav__item + .nav__item {
      border-top: 1px solid hsla(var(--dark-gray), 0.2);
    }

    .nav__link {
      display: block;
      padding: 1.5em;
      color: hsl(var(--black));
    }

    .nav__link:hover,
    .nav__link:focus {
      background-color: hsl(var(--accent));
      color: hsl(var(--white));
    }
  }

  @media (min-width: 1000px) {
    .nav__link {
      font-size: var(--fs-300);
      letter-spacing: -0.04em;
      color: hsl(var(--white));
    }

    .nav__link:focus,
    .nav__link:hover {
      opacity: 1;
      padding-bottom: 0.2em;
      border-bottom: 3px solid hsl(var(--white));
    }
  }
</style>
